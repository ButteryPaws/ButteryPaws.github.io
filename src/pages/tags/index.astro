---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prompt from '../../components/Prompt.astro';

const notDraft = ({ data }: any) => !data.draft;
const all = [
  ...(await getCollection('blog', notDraft)),
  ...(await getCollection('ctf', notDraft)),
];

// Count posts per tag across both collections.
const counts = new Map<string, number>();
for (const post of all) {
  for (const tag of post.data.tags ?? []) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort((a, b) =>
  b[1] - a[1] || a[0].localeCompare(b[0])
);
---

<BaseLayout title="tags" description="Browse posts by tag.">
  <div class="page-head">
    <div class="page-head__cmd"><Prompt path="~" cmd="grep -rl tags/" /></div>
    <h1>tags</h1>
    <p class="page-head__desc">{tags.length} tags across blog and ctf.</p>
  </div>

  {
    tags.length === 0 ? (
      <p class="muted">// no tags yet</p>
    ) : (
      <ul class="tags">
        {tags.map(([tag, count]) => (
          <li>
            <a class="tag tag--lg" href={`/tags/${tag}`}>
              {tag}<span class="tag__count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
